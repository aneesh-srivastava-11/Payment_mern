generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String        @id @default(uuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  customers    Customer[]
  invoices     Invoice[]
  usageRecords UsageRecord[]
}

model User {
  id            String         @id @default(uuid())
  tenantId      String
  email         String         @unique
  name          String?
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  subscriptions Subscription[]
  customers     Customer[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Plan {
  id              String         @id @default(uuid())
  name            String         // e.g., 'free', 'pro'
  price           Int            // in cents
  currency        String         @default("usd")
  providerPriceId String?        // ID on the payment provider side (e.g. Stripe Price ID)
  trialDays       Int?           @default(0)
  subscriptions   Subscription[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  TRIALING
  INCOMPLETE
  EXPIRED
  PAUSED
}

model Subscription {
  id                 String             @id @default(uuid())
  userId             String
  planId             String
  providerSubId      String?            @unique // ID on the payment provider side
  providerCustomerId String?            // Customer ID on the payment provider side
  status             SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  trialEndsAt        DateTime?
  dunningRetryCount  Int                @default(0)
  dunningLastAttempt DateTime?
  user               User               @relation(fields: [userId], references: [id])
  plan               Plan               @relation(fields: [planId], references: [id])
  invoices           Invoice[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([userId, planId])
}

model Customer {
  id                 String   @id @default(uuid())
  tenantId           String
  userId             String
  provider           String   // e.g., 'stripe' or 'razorpay'
  providerCustomerId String   @unique
  createdAt          DateTime @default(now())

  tenant             Tenant   @relation(fields: [tenantId], references: [id])
  user               User     @relation(fields: [userId], references: [id])

  @@unique([userId, provider])
}

model BillingEvent {
  id             String   @id @default(uuid())
  tenantId       String
  subscriptionId String?
  provider       String   // e.g., 'stripe' or 'razorpay'
  eventType      String
  payload        Json
  processed      Boolean  @default(false)
  providerEventId String?  @unique // unique transaction or webhook event ID
  createdAt      DateTime @default(now())
}

model Invoice {
  id                String       @id @default(uuid())
  subscriptionId    String
  tenantId          String
  providerInvoiceId String?      @unique
  amount            Int
  currency          String       @default("usd")
  status            String       // e.g., paid, pending, failed, refunded
  issuedAt          DateTime     @default(now())
  paidAt            DateTime?
  invoiceUrl        String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  subscription      Subscription @relation(fields: [subscriptionId], references: [id])
}

model UsageRecord {
  id        String   @id @default(uuid())
  tenantId  String
  action    String   // e.g., 'api_call', 'image_generation'
  usage     Int
  timestamp DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}
