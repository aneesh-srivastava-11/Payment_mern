# Server Config
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Config (PostgreSQL connection string)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/billing_db?schema=public"

# Default provider choice ('stripe', 'razorpay', or 'mock')
DEFAULT_PAYMENT_PROVIDER=mock

# Dunning Config
DUNNING_RETRY_LIMIT=3

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Razorpay Configuration
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=key_secret_...
RAZORPAY_WEBHOOK_SECRET=whsec_rzp_...
